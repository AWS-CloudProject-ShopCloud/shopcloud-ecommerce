  "version": "1.0.0",
  "description": "Simple E-commerce Backend using AWS Services (EC2, DynamoDB, Lambda, Cognito, S3)",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
