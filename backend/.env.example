# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=PASTE_YOUR_ACCESS_KEY_HERE
AWS_SECRET_ACCESS_KEY=PASTE_YOUR_SECRET_KEY_HERE
AWS_SESSION_TOKEN=PASTE_YOUR_SESSION_TOKEN_HERE

# ─── AWS Cognito (Real) ────────────────────────────────────────────────────────
# Get these after creating a User Pool in the AWS Cognito Console
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── DynamoDB ─────────────────────────────────────────────────────────────────
DYNAMODB_PRODUCTS_TABLE=ecommerce-products
DYNAMODB_USERS_TABLE=ecommerce-users

# ─── S3 ───────────────────────────────────────────────────────────────────────
S3_RECEIPTS_BUCKET=ecommerce-receipts-devraj2026

# ─── Lambda ───────────────────────────────────────────────────────────────────
LAMBDA_FUNCTION_NAME=ecommerce-process-purchase

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
